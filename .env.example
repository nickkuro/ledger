# Copy this file to .env and fill in real values. Never commit the real .env file.

# From the Discord Developer Portal > your application > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Must exactly match a redirect registered in the Discord Developer Portal,
# including http vs https. Example for local testing:
#   DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
# Example once deployed:
#   DISCORD_REDIRECT_URI=https://notes.yourdomain.com/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Any long random string, used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional. Comma-separated Discord user IDs allowed to log in.
# Leave blank to let any Discord account log in.
# Find a user ID by enabling Developer Mode in Discord (User Settings > Advanced),
# then right-click a person > Copy User ID.
# This is just the baseline list — once the app is running, the admin
# (ADMIN_DISCORD_ID) can add/remove IDs from the "Manage access" panel
# in Settings instead of editing this.
ALLOWED_DISCORD_IDS=

# Discord Bot token — required for Send to DMs and Reminders.
# In the Discord Developer Portal, go to your app → Bot → Reset Token.
# The bot does NOT need to be in any server to send DMs.
BOT_TOKEN=

# Optional. Discord user ID for the site admin -- gets the Manage Access
# panel and their own Bills tab by default. Other people can be granted
# their own separate Bills tab from that panel once the app is running.
# Find a user ID by enabling Developer Mode in Discord (User Settings > Advanced),
# then right-click a person > Copy User ID.
ADMIN_DISCORD_ID=

# Set to "production" when deployed behind HTTPS so session cookies require it
NODE_ENV=development
